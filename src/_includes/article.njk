---
layout: base.njk
---
<article class="article-page">
  <header class="article-header">
    <p class="eyebrow">{{ category or "Investigation" }}</p>
    <h1>{{ title }}</h1>
    <div class="article-meta">
      <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
      {% if author %}<span>By {{ author }}</span>{% endif %}
    </div>
    {% if summary %}<p class="dek">{{ summary }}</p>{% endif %}
    {% if featured_image %}
      <img class="featured-image" src="{{ featured_image }}" alt="{{ image_alt or title }}">
    {% endif %}
  </header>

  <div class="article-body">
    {{ content | safe }}
  </div>
<div class="article-share">
  <button type="button" id="share-article">
    Share this article
  </button>

  <span id="share-status" aria-live="polite"></span>
</div>

<script>
  const shareButton = document.getElementById("share-article");
  const shareStatus = document.getElementById("share-status");

  shareButton.addEventListener("click", async () => {
    const description =
      document.querySelector('meta[name="description"]')?.content ||
      document.title;

    const shareDetails = {
      title: document.title,
      text: description,
      url: window.location.href
    };

    try {
      if (navigator.share) {
        await navigator.share(shareDetails);
      } else {
        await navigator.clipboard.writeText(window.location.href);
        shareStatus.textContent = "Article link copied!";
      }
    } catch (error) {
      shareStatus.textContent = "Please copy the page address from your browser.";
    }
  });
</script>
  {% if sources %}
  <section class="sources">
    <h2>Sources</h2>
    <ul>
      {% for source in sources %}
      <li><a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.label }}</a></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</article>
