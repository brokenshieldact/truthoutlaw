---
layout: base.njk
title: Home
description: Independent articles, timelines, source material, and community submissions.
---
<section class="hero">
  <div class="hero-overlay">
    <p class="eyebrow">Independent publishing and public record</p>
    <h1>{{ site.tagline }}</h1>
    <p class="hero-copy">{{ site.description }}</p>
    <div class="button-row">
      <a class="button primary" href="#articles">Read articles</a>
      <a class="button secondary" href="/submit/">Submit information</a>
    </div>
  </div>
</section>

<section id="articles" class="section">
  <div class="section-heading">
    <p class="eyebrow">Latest reporting</p>
    <h2>Articles</h2>
  </div>

  <div class="article-grid">
    {% for article in collections.articles | limit(6) %}
    <article class="article-card">
      {% if article.data.featured_image %}
        <img src="{{ article.data.featured_image }}" alt="{{ article.data.image_alt or article.data.title }}">
      {% endif %}
      <div class="article-card-copy">
        <time datetime="{{ article.date | isoDate }}">{{ article.date | readableDate }}</time>
        <p class="category">{{ article.data.category or "Investigation" }}</p>
        <h3><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
        <p>{{ article.data.summary }}</p>
        <a class="read-link" href="{{ article.url }}">Read article</a>
      </div>
    </article>
    {% endfor %}
  </div>

  <div class="section-action">
    <a class="button secondary" href="/timeline/">View full timeline</a>
  </div>
</section>
